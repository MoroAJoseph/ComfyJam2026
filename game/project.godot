; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Beached Bounty"
run/main_scene="uid://d23ynsioags2n"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=240
run/low_processor_mode=true
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://core/services/audio/default_bus_layout.tres"

[autoload]

Session="*uid://bl316tibj2tck"
EventBus="*uid://dm4eknlbg7dpt"
DialogueManager="*uid://ba4exd0o5s3pu"
Dialogic="*uid://ds2q0uclmolvu"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1

[dialogic]

directories/dch_directory={
"player": "res://features/narrative/characters/player.dch",
"sand_witch": "res://features/narrative/characters/sand_witch.dch"
}
directories/dtl_directory={
"log_page_1_1": "res://features/narrative/timelines/navigator_logs/log_page_1_1.dtl",
"log_page_2_3": "res://features/narrative/timelines/navigator_logs/log_page_2_3.dtl",
"main_timeline": "res://features/narrative/timelines/main_timeline.dtl",
"sand_witch_first_meet": "res://features/narrative/timelines/sand_witch_first_meet.dtl"
}
layout/style_directory={
"": "res://features/narrative/styles/main_style.tres",
"main_style": "res://features/narrative/styles/main_style.tres"
}
layout/style_list=["res://features/narrative/styles/main_style.tres"]
layout/default_style="res://features/narrative/styles/main_style.tres"
variables={
"user_response": ""
}

[display]

window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/kanban_tasks/plugin.cfg")

[file_customization]

folder_colors={
"res://_dev/": "blue",
"res://addons/": "gray",
"res://assets/": "orange",
"res://common/": "green",
"res://core/": "red",
"res://core/voxel_engine/": "blue",
"res://docs/": "pink",
"res://features/": "purple",
"res://ui/": "blue"
}

